# Токен бота MAX (обязательно)
BOT_TOKEN=your_bot_token_here

# ID администратора (обязательно для команд /stats и /broadcast)
ADMIN_ID=12345678

# Настройки словаря (опционально)
DICTIONARY_FILE=dictionary.xlsx
FUZZY_THRESHOLD=0.7
MAX_SUGGESTIONS=5

# Файлы для хранения данных (опционально)
USERS_FILE=users.json
FEEDBACK_FILE=feedback.json